# --- Supabase (Auth + Postgres) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Postgres connection (used ONLY by local scripts: migrate + seed).
# Use the Supabase "Session pooler" URI (IPv4) so it works everywhere.
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres
SUPABASE_DB_PASSWORD=your-db-password

# --- Demo account (one-click "Try the demo") ---
DEMO_EMAIL=demo@vault.app
DEMO_PASSWORD=vault-demo-2026!

# --- Krava (privacy-first AI) ---
KRAVA_APP_KEY=your_krava_app_key
KRAVA_BASE_URL=https://krava.io

# --- Plaid (connect real bank data) ---
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox
